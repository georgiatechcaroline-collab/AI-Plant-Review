rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Snapshots: Public read, write restricted to secret-holders (Raspberry Pi)
    match /snapshots/{snapshotId} {
      allow read: if true;
      // IMPORTANT: Replace "<YOUR_UPLOAD_SECRET>" with the same secret password 
      // you set in your Vercel/AI Studio environment variables (UPLOAD_SECRET).
      allow create: if request.resource.data.secret == "<YOUR_UPLOAD_SECRET>" 
                   && request.resource.data.image is string
                   && request.resource.data.image.size() > 0;
      allow update, delete: if false;
    }
  }
}
